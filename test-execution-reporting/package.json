{
  "name": "test-execution-reporting-system",
  "version": "1.0.0",
  "description": "Enterprise Test Execution Reporting System with comprehensive data capture, storage, and visualization capabilities for scalable automation testing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "setup:db": "ts-node scripts/setup-database.ts",
    "consolidate": "node scripts/consolidate-results.js",
    "migrate:aws": "ts-node scripts/migrate-to-aws.ts",
    "export:excel": "ts-node scripts/export-excel.ts",
    "export:csv": "ts-node scripts/export-csv.ts",
    "dashboard:build": "npm run build && npm run dashboard:generate",
    "dashboard:generate": "ts-node scripts/generate-dashboard.ts",
    "dashboard:serve": "http-server src/dashboard -p 8080 -c-1",
    "generate:trends": "ts-node scripts/generate-trends.ts",
    "health:check": "ts-node scripts/health-check.ts",
    "backup": "ts-node scripts/backup-data.ts",
    "restore": "ts-node scripts/restore-data.ts",
    "clean": "rimraf dist coverage",
    "prepack": "npm run clean && npm run build"
  },
  "bin": {
    "test-execution-reporting": "./dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "src/dashboard/**/*",
    "scripts/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "test-automation",
    "reporting",
    "playwright",
    "typescript",
    "dashboard",
    "ci-cd",
    "github-actions",
    "sqlite",
    "excel-export",
    "csv-export",
    "analytics",
    "metrics",
    "enterprise",
    "scalable",
    "aws-migration"
  ],
  "author": {
    "name": "Senior QA Automation Architect",
    "email": "qa-automation@company.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/company/test-execution-reporting.git"
  },
  "bugs": {
    "url": "https://github.com/company/test-execution-reporting/issues"
  },
  "homepage": "https://github.com/company/test-execution-reporting#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "sqlite3": "^5.1.6",
    "exceljs": "^4.4.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "csv-writer": "^1.6.0",
    "csv-parser": "^3.0.0",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "table": "^6.8.1",
    "aws-sdk": "^2.1490.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/uuid": "^9.0.5",
    "@types/lodash": "^4.14.199",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.5",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.5",
    "http-server": "^14.1.1",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.16"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.30.0"
  },
  "optionalDependencies": {
    "sharp": "^0.32.6"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/dashboard/**/*"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "@typescript-eslint/recommended"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/no-explicit-any": "warn",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false
  },
  "config": {
    "storage": {
      "type": "sqlite",
      "path": "./data/execution-history.db"
    },
    "dashboard": {
      "port": 8080,
      "autoRefresh": true,
      "refreshInterval": 30000
    },
    "export": {
      "formats": ["excel", "csv", "json"],
      "outputDir": "./reports"
    },
    "aws": {
      "region": "us-east-1",
      "s3Bucket": "test-execution-reporting",
      "dynamoTablePrefix": "test-execution",
      "athenaDatabase": "test_execution_db"
    }
  }
}
{
  "environment": "sit",
  "baseUrl": "https://sit-demowebshop.tricentis.com",
  "apiBaseUrl": "https://sit-api.tricentis.com/v1",
  "timeout": 45000,
  "retries": 3,
  "headless": true,
  "slowMo": 0,
  "database": {
    "host": "sit-db.company.com",
    "port": 5432,
    "database": "testdb_sit",
    "username": "test_user",
    "password": "${SIT_DB_PASSWORD}",
    "connectionString": "${SIT_DB_CONNECTION}"
  },
  "features": {
    "registration": {
      "enabled": true,
      "url": "/register",
      "apiEndpoint": "/api/users/register"
    },
    "login": {
      "enabled": true,
      "url": "/login",
      "apiEndpoint": "/api/auth/login"
    },
    "checkout": {
      "enabled": true,
      "url": "/checkout",
      "apiEndpoint": "/api/orders"
    }
  },
  "testData": {
    "users": {
      "validUser": {
        "firstName": "Jane",
        "lastName": "Smith",
        "email": "jane.smith.sit@test.com",
        "password": "SitPass123!"
      },
      "adminUser": {
        "email": "admin.sit@test.com",
        "password": "AdminSit123!"
      }
    },
    "products": {
      "sampleProduct": {
        "id": "sit-product-001",
        "name": "Test Product SIT",
        "price": 149.99
      }
    }
  },
  "integrations": {
    "jira": {
      "enabled": true,
      "projectKey": "TAF-SIT"
    },
    "slack": {
      "enabled": true,
      "channel": "#test-automation-sit"
    },
    "browserstack": {
      "enabled": true
    },
    "aws": {
      "enabled": true,
      "s3Bucket": "taf-sit-reports"
    }
  },
  "performance": {
    "loadUsers": 50,
    "duration": 300,
    "thresholds": {
      "responseTime": 1500,
      "errorRate": 3
    }
  },
  "security": {
    "enableSecurityTests": true,
    "skipSslVerification": false
  }
}
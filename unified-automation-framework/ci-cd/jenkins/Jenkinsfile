pipeline {
    agent {
        kubernetes {
            yaml """
                apiVersion: v1
                kind: Pod
                spec:
                  containers:
                  - name: maven
                    image: maven:3.9.5-openjdk-21
                    command:
                    - cat
                    tty: true
                    volumeMounts:
                    - name: docker-sock
                      mountPath: /var/run/docker.sock
                  - name: docker
                    image: docker:24.0.7-dind
                    securityContext:
                      privileged: true
                    volumeMounts:
                    - name: docker-sock
                      mountPath: /var/run/docker.sock
                  - name: kubectl
                    image: bitnami/kubectl:1.28
                    command:
                    - cat
                    tty: true
                  - name: helm
                    image: alpine/helm:3.13.2
                    command:
                    - cat
                    tty: true
                  volumes:
                  - name: docker-sock
                    hostPath:
                      path: /var/run/docker.sock
            """
        }
    }

    environment {
        DOCKER_REGISTRY = 'your-registry.com'
        KUBECONFIG = credentials('kubeconfig')
        SONAR_TOKEN = credentials('sonar-token')
        SLACK_WEBHOOK = credentials('slack-webhook')
        TEST_ENVIRONMENT = "${params.ENVIRONMENT ?: 'staging'}"
        PARALLEL_EXECUTION = "${params.PARALLEL_JOBS ?: '10'}"
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['staging', 'production'],
            description: 'Target environment for deployment'
        )
        string(
            name: 'PARALLEL_JOBS',
            defaultValue: '10',
            description: 'Number of parallel test execution jobs'
        )
        booleanParam(
            name: 'RUN_PERFORMANCE_TESTS',
            defaultValue: false,
            description: 'Execute performance test suite'
        )
        booleanParam(
            name: 'RUN_SECURITY_TESTS',
            defaultValue: false,
            description: 'Execute security test suite'
        )
        booleanParam(
            name: 'DEPLOY_TO_PRODUCTION',
            defaultValue: false,
            description: 'Deploy to production environment'
        )
    }

    stages {
        stage('Checkout & Setup') {
            steps {
                checkout scm
                script {
                    env.BUILD_VERSION = sh(
                        script: "echo '${env.BUILD_NUMBER}-${env.GIT_COMMIT[0..7]}'",
                        returnStdout: true
                    ).trim()
                    env.IMAGE_TAG = "${env.BUILD_VERSION}"
                }
            }
        }

        stage('Code Quality & Security') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        container('maven') {
                            sh '''
                                cd services/test-manager
                                mvn clean test -Dspring.profiles.active=test
                                mvn jacoco:report
                            '''
                        }
                    }
                    post {
                        always {
                            publishTestResults testResultsPattern: '**/target/surefire-reports/*.xml'
                            publishCoverage adapters: [
                                jacocoAdapter('**/target/site/jacoco/jacoco.xml')
                            ]
                        }
                    }
                }

                stage('SonarQube Analysis') {
                    steps {
                        container('maven') {
                            sh '''
                                cd services/test-manager
                                mvn sonar:sonar \
                                    -Dsonar.projectKey=test-automation-framework \
                                    -Dsonar.host.url=https://sonarqube.company.com \
                                    -Dsonar.login=${SONAR_TOKEN}
                            '''
                        }
                    }
                }

                stage('Security Scan') {
                    steps {
                        container('maven') {
                            sh '''
                                # OWASP Dependency Check
                                cd services/test-manager
                                mvn org.owasp:dependency-check-maven:check
                                
                                # Trivy vulnerability scan
                                curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin
                                trivy fs --exit-code 1 --severity HIGH,CRITICAL .
                            '''
                        }
                    }
                }
            }
        }

        stage('Build & Package') {
            parallel {
                stage('Build Java Services') {
                    steps {
                        container('maven') {
                            sh '''
                                cd services/test-manager
                                mvn clean package -DskipTests
                            '''
                        }
                    }
                }

                stage('Build Go Services') {
                    steps {
                        container('docker') {
                            sh '''
                                cd services/execution-orchestrator
                                docker build -t ${DOCKER_REGISTRY}/execution-orchestrator:${IMAGE_TAG} .
                            '''
                        }
                    }
                }

                stage('Build Python Services') {
                    steps {
                        container('docker') {
                            sh '''
                                cd services/ai-engine
                                docker build -t ${DOCKER_REGISTRY}/ai-engine:${IMAGE_TAG} .
                            '''
                        }
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                container('docker') {
                    script {
                        def services = ['test-manager', 'execution-orchestrator', 'ai-engine']
                        services.each { service ->
                            sh """
                                cd services/${service}
                                docker build -t ${DOCKER_REGISTRY}/${service}:${IMAGE_TAG} .
                                docker push ${DOCKER_REGISTRY}/${service}:${IMAGE_TAG}
                                docker tag ${DOCKER_REGISTRY}/${service}:${IMAGE_TAG} ${DOCKER_REGISTRY}/${service}:latest
                                docker push ${DOCKER_REGISTRY}/${service}:latest
                            """
                        }
                    }
                }
            }
        }

        stage('Integration Tests') {
            steps {
                container('maven') {
                    sh '''
                        # Start test environment
                        docker-compose -f docker-compose.test.yml up -d
                        
                        # Wait for services to be ready
                        sleep 30
                        
                        # Run integration tests
                        cd integration-tests
                        mvn test -Dtest.environment=integration
                        
                        # Cleanup
                        docker-compose -f docker-compose.test.yml down
                    '''
                }
            }
            post {
                always {
                    publishTestResults testResultsPattern: '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Deploy to Staging') {
            when {
                anyOf {
                    branch 'main'
                    branch 'develop'
                }
            }
            steps {
                container('helm') {
                    sh '''
                        # Update Helm chart values
                        helm upgrade --install test-automation-staging ./helm/test-automation \
                            --namespace test-automation-staging \
                            --create-namespace \
                            --set image.tag=${IMAGE_TAG} \
                            --set environment=staging \
                            --set replicaCount.testManager=2 \
                            --set replicaCount.executionOrchestrator=3 \
                            --set replicaCount.aiEngine=2 \
                            --wait --timeout=10m
                    '''
                }
            }
        }

        stage('Automated Testing Suite') {
            when {
                anyOf {
                    branch 'main'
                    branch 'develop'
                }
            }
            parallel {
                stage('Smoke Tests') {
                    steps {
                        container('maven') {
                            sh '''
                                cd automated-tests
                                mvn test -Dtest.suite=smoke \
                                    -Dtest.environment=${TEST_ENVIRONMENT} \
                                    -Dparallel.jobs=${PARALLEL_EXECUTION}
                            '''
                        }
                    }
                }

                stage('API Tests') {
                    steps {
                        container('maven') {
                            sh '''
                                cd automated-tests
                                mvn test -Dtest.suite=api \
                                    -Dtest.environment=${TEST_ENVIRONMENT} \
                                    -Dparallel.jobs=${PARALLEL_EXECUTION}
                            '''
                        }
                    }
                }

                stage('UI Tests') {
                    steps {
                        container('maven') {
                            sh '''
                                cd automated-tests
                                mvn test -Dtest.suite=ui \
                                    -Dtest.environment=${TEST_ENVIRONMENT} \
                                    -Dparallel.jobs=${PARALLEL_EXECUTION} \
                                    -Dselenium.grid.url=http://selenium-hub-service.test-automation.svc.cluster.local:4444
                            '''
                        }
                    }
                }

                stage('Performance Tests') {
                    when {
                        expression { params.RUN_PERFORMANCE_TESTS }
                    }
                    steps {
                        container('maven') {
                            sh '''
                                cd performance-tests
                                mvn gatling:test \
                                    -Dgatling.simulationClass=LoadTestSimulation \
                                    -Dtarget.url=https://staging.company.com
                            '''
                        }
                    }
                }

                stage('Security Tests') {
                    when {
                        expression { params.RUN_SECURITY_TESTS }
                    }
                    steps {
                        container('maven') {
                            sh '''
                                # OWASP ZAP security testing
                                docker run -t owasp/zap2docker-stable zap-baseline.py \
                                    -t https://staging.company.com \
                                    -J zap-report.json
                            '''
                        }
                    }
                }
            }
            post {
                always {
                    publishTestResults testResultsPattern: '**/target/surefire-reports/*.xml'
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'target/gatling',
                        reportFiles: 'index.html',
                        reportName: 'Performance Test Report'
                    ])
                }
            }
        }

        stage('Deploy to Production') {
            when {
                allOf {
                    branch 'main'
                    expression { params.DEPLOY_TO_PRODUCTION }
                }
            }
            steps {
                script {
                    timeout(time: 5, unit: 'MINUTES') {
                        input message: 'Deploy to Production?', 
                              parameters: [
                                  booleanParam(defaultValue: false, 
                                             description: 'Confirm production deployment', 
                                             name: 'CONFIRM_DEPLOY')
                              ]
                    }
                }
                container('helm') {
                    sh '''
                        helm upgrade --install test-automation-prod ./helm/test-automation \
                            --namespace test-automation-prod \
                            --create-namespace \
                            --set image.tag=${IMAGE_TAG} \
                            --set environment=production \
                            --set replicaCount.testManager=5 \
                            --set replicaCount.executionOrchestrator=10 \
                            --set replicaCount.aiEngine=5 \
                            --set resources.requests.memory=4Gi \
                            --set resources.requests.cpu=2000m \
                            --wait --timeout=15m
                    '''
                }
            }
        }

        stage('Post-Deployment Validation') {
            when {
                expression { params.DEPLOY_TO_PRODUCTION }
            }
            steps {
                container('maven') {
                    sh '''
                        # Health checks
                        curl -f https://api.company.com/health || exit 1
                        
                        # Critical path tests
                        cd automated-tests
                        mvn test -Dtest.suite=critical-path \
                            -Dtest.environment=production \
                            -Dparallel.jobs=5
                    '''
                }
            }
        }
    }

    post {
        always {
            // Archive artifacts
            archiveArtifacts artifacts: '**/target/*.jar,**/target/site/jacoco/**,**/reports/**', 
                           fingerprint: true

            // Cleanup
            container('docker') {
                sh 'docker system prune -f'
            }
        }
        
        success {
            script {
                if (env.BRANCH_NAME == 'main') {
                    slackSend(
                        channel: '#test-automation',
                        color: 'good',
                        message: """
                            ✅ *Test Automation Framework - Deployment Successful*
                            
                            *Branch:* ${env.BRANCH_NAME}
                            *Build:* ${env.BUILD_NUMBER}
                            *Version:* ${env.BUILD_VERSION}
                            *Environment:* ${env.TEST_ENVIRONMENT}
                            
                            *Test Results:*
                            • Unit Tests: ✅ Passed
                            • Integration Tests: ✅ Passed
                            • Security Scan: ✅ Passed
                            
                            <${env.BUILD_URL}|View Build Details>
                        """.stripIndent(),
                        webhookUrl: env.SLACK_WEBHOOK
                    )
                }
            }
        }
        
        failure {
            slackSend(
                channel: '#test-automation',
                color: 'danger',
                message: """
                    ❌ *Test Automation Framework - Build Failed*
                    
                    *Branch:* ${env.BRANCH_NAME}
                    *Build:* ${env.BUILD_NUMBER}
                    *Stage:* ${env.STAGE_NAME}
                    
                    <${env.BUILD_URL}|View Build Details>
                    <${env.BUILD_URL}console|View Console Output>
                """.stripIndent(),
                webhookUrl: env.SLACK_WEBHOOK
            )
        }
    }
}
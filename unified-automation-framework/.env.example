# Enterprise Test Automation Framework - Environment Configuration

# =========================
# APPLICATION SETTINGS
# =========================
NODE_ENV=development
APP_NAME=Enterprise Test Automation Framework
APP_VERSION=1.0.0

# =========================
# TEST ENVIRONMENT URLS
# =========================
DEV_BASE_URL=https://dev.company.com
STAGING_BASE_URL=https://staging.company.com
PROD_BASE_URL=https://company.com

# =========================
# DATABASE CONNECTIONS
# =========================
DEV_DB_CONNECTION=postgresql://user:password@dev-db:5432/testdb
STAGING_DB_CONNECTION=postgresql://user:password@staging-db:5432/testdb
PROD_DB_CONNECTION=postgresql://user:password@prod-db:5432/testdb

# MongoDB connections
DEV_MONGO_CONNECTION=mongodb://user:password@dev-mongo:27017/testdb
STAGING_MONGO_CONNECTION=mongodb://user:password@staging-mongo:27017/testdb

# =========================
# JIRA INTEGRATION
# =========================
JIRA_URL=https://company.atlassian.net
JIRA_USERNAME=automation@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=TAF

# =========================
# BROWSERSTACK INTEGRATION
# =========================
BROWSERSTACK_USERNAME=your_browserstack_username
BROWSERSTACK_ACCESS_KEY=your_browserstack_access_key
BROWSERSTACK_BUILD_NAME=TAF_Build_${BUILD_NUMBER}
BROWSERSTACK_PROJECT_NAME=Enterprise_Test_Automation

# =========================
# AWS CONFIGURATION
# =========================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_REPORTS=taf-test-reports
AWS_S3_BUCKET_SCREENSHOTS=taf-screenshots
AWS_S3_BUCKET_ARTIFACTS=taf-artifacts

# =========================
# SLACK INTEGRATION
# =========================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#test-automation
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# =========================
# EMAIL NOTIFICATIONS
# =========================
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=automation@company.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=automation@company.com
EMAIL_TO_SUCCESS=qa-team@company.com
EMAIL_TO_FAILURE=dev-team@company.com,qa-lead@company.com

# =========================
# TEST EXECUTION SETTINGS
# =========================
PARALLEL_WORKERS=4
TEST_TIMEOUT=30000
RETRY_ATTEMPTS=3
HEADLESS=true
SLOW_MO=0

# =========================
# PERFORMANCE SETTINGS
# =========================
PERFORMANCE_BUDGET_LOAD_TIME=3000
PERFORMANCE_BUDGET_FCP=1800
PERFORMANCE_BUDGET_LCP=2500
PERFORMANCE_BUDGET_CLS=0.1

# =========================
# SECURITY SETTINGS
# =========================
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here
API_KEY=your_api_key_here

# =========================
# MONITORING AND LOGGING
# =========================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/test-execution.log
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=true

# =========================
# CI/CD SETTINGS
# =========================
BUILD_NUMBER=${BUILD_NUMBER}
GIT_COMMIT=${GIT_COMMIT}
GIT_BRANCH=${GIT_BRANCH}
BUILD_URL=${BUILD_URL}

# =========================
# MOBILE TESTING
# =========================
APPIUM_SERVER_URL=http://localhost:4723/wd/hub
ANDROID_APP_PATH=./apps/android/app.apk
IOS_APP_PATH=./apps/ios/app.ipa
DEVICE_FARM_PROJECT_ARN=arn:aws:devicefarm:us-west-2:123456789012:project:your-project-id

# =========================
# API TESTING
# =========================
API_BASE_URL=https://api.company.com/v1
API_KEY=your_api_key_here
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# =========================
# LOAD TESTING
# =========================
LOAD_TEST_USERS=100
LOAD_TEST_DURATION=300
LOAD_TEST_RAMP_UP=60
LOAD_TEST_THINK_TIME=1000

# =========================
# ACCESSIBILITY TESTING
# =========================
AXE_CORE_VERSION=4.7.0
WCAG_LEVEL=AA
ACCESSIBILITY_STANDARDS=wcag2a,wcag2aa,wcag21aa

# =========================
# VISUAL TESTING
# =========================
PERCY_TOKEN=your_percy_token_here
APPLITOOLS_API_KEY=your_applitools_api_key
VISUAL_DIFF_THRESHOLD=0.1

# =========================
# THIRD-PARTY INTEGRATIONS
# =========================
GITHUB_TOKEN=your_github_token
SONARQUBE_URL=https://sonarqube.company.com
SONARQUBE_TOKEN=your_sonarqube_token

# =========================
# DOCKER SETTINGS
# =========================
DOCKER_REGISTRY=your-registry.company.com
DOCKER_IMAGE_TAG=latest
SELENIUM_HUB_URL=http://selenium-hub:4444/wd/hub

# =========================
# KUBERNETES SETTINGS
# =========================
K8S_NAMESPACE=test-automation
K8S_CONFIG_PATH=~/.kube/config
K8S_CLUSTER_NAME=test-cluster

# =========================
# FEATURE FLAGS
# =========================
ENABLE_VISUAL_TESTING=false
ENABLE_PERFORMANCE_TESTING=true
ENABLE_SECURITY_TESTING=true
ENABLE_ACCESSIBILITY_TESTING=true
ENABLE_MOBILE_TESTING=false
ENABLE_API_TESTING=true

# =========================
# DEBUG SETTINGS
# =========================
DEBUG_MODE=false
VERBOSE_LOGGING=false
SAVE_SCREENSHOTS_ON_PASS=false
SAVE_VIDEOS=true
TRACE_VIEWER=false

# =========================
# CLEANUP SETTINGS
# =========================
CLEANUP_TEST_DATA=true
CLEANUP_SCREENSHOTS=true
CLEANUP_VIDEOS=true
CLEANUP_REPORTS=false
RETENTION_DAYS=30
{
  "name": "enterprise-test-automation-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade test automation framework with Playwright, supporting microservices architecture and multi-tenant testing",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:dev": "TEST_ENV=dev playwright test",
    "test:sit": "TEST_ENV=sit playwright test",
    "test:preprod": "TEST_ENV=preprod playwright test",
    "test:prod": "TEST_ENV=prod playwright test --grep @smoke",
    "test:registration": "playwright test tests/registration/",
    "test:registration-ui": "playwright test tests/registration/registration.spec.ts",
    "test:registration-api": "playwright test tests/registration/registration-api.spec.ts",
    "test:registration-chrome": "TEST_ENV=prod playwright test tests/registration/ --project=chrome --reporter=allure-playwright",
    "test:registration-chrome-headed": "TEST_ENV=prod playwright test tests/registration/ --project=chrome --headed --reporter=allure-playwright",
    "test:api": "playwright test tests/api/",
    "test:database": "playwright test tests/database/",
    "test:performance": "playwright test tests/performance/",
    "test:security": "playwright test tests/security/",
    "test:mobile": "playwright test tests/mobile/",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:parallel": "playwright test --workers=4",
    "test:cross-browser": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:ci": "playwright test --reporter=junit",
    "test:retry": "playwright test --last-failed --retries=3",
    "test:report": "playwright show-report",
    "test:allure": "allure generate allure-results --clean && allure open",
    "env:dev": "TEST_ENV=dev",
    "env:sit": "TEST_ENV=sit",
    "env:preprod": "TEST_ENV=preprod",
    "env:prod": "TEST_ENV=prod",
    "env:list": "node -e \"console.log('Available environments:', require('./src/utils/environment-manager').EnvironmentManager.getAvailableEnvironments().join(', '))\"",
    "env:validate": "node -e \"const {envManager} = require('./dist/src/utils/environment-manager'); const result = envManager.validateConfig(); console.log(result.valid ? '✅ Configuration valid' : '❌ Configuration errors:', result.errors)\"",
    "env:summary": "node -e \"const {envManager} = require('./dist/src/utils/environment-manager'); envManager.printConfigSummary()\"",
    "install:browsers": "playwright install",
    "install:deps": "playwright install-deps",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist test-results playwright-report allure-results allure-report coverage",
    "pretest": "npm run build",
    "posttest": "npm run test:report",
    "prepare": "husky install",
    "docker:build": "docker build -t test-automation-framework .",
    "docker:run": "docker run --rm -v $(pwd)/test-results:/app/test-results test-automation-framework",
    "k8s:deploy": "kubectl apply -f infrastructure/kubernetes/",
    "k8s:delete": "kubectl delete -f infrastructure/kubernetes/",
    "generate:test-data": "node scripts/generate-test-data.js",
    "validate:test-data": "node scripts/validate-test-data.js",
    "update-snapshots": "playwright test --update-snapshots"
  },
  "keywords": [
    "playwright",
    "typescript",
    "test-automation",
    "enterprise",
    "microservices",
    "multi-tenant",
    "page-object-model",
    "ci-cd",
    "cross-browser",
    "performance-testing",
    "api-testing",
    "security-testing"
  ],
  "author": "Enterprise Test Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@playwright/test": "^1.48.0",
    "@types/jest": "^29.5.5",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.0.0",
    "eslint-plugin-playwright": "^1.6.0",
    "eslint-plugin-prettier": "^5.2.0",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.4.0",
    "mongodb": "^6.8.0",
    "mysql2": "^3.11.0",
    "pg": "^8.12.0",
    "better-sqlite3": "^11.3.0",
    "winston": "^3.14.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ram0309/learningNewSkill.git"
  },
  "bugs": {
    "url": "https://github.com/Ram0309/learningNewSkill/issues"
  },
  "homepage": "https://github.com/Ram0309/learningNewSkill#readme"
}

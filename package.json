{
  "name": "unified-automation-framework",
  "version": "1.0.0",
  "description": "Comprehensive test automation framework with Playwright + TypeScript",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --grep @ui",
    "test:api": "playwright test --grep @api",
    "test:mobile": "playwright test --grep @mobile",
    "test:performance": "npm run test:k6 && npm run test:artillery",
    "test:security": "npm run test:zap && npm run test:nuclei",
    "test:database": "playwright test --grep @database",
    "test:k6": "k6 run tests/performance/k6/**/*.js",
    "test:artillery": "artillery run tests/performance/artillery/**/*.yml",
    "test:zap": "node tests/security/zap-runner.js",
    "test:nuclei": "nuclei -t tests/security/nuclei-templates/ -u $TARGET_URL",
    "test:parallel": "playwright test --workers=10",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "allure serve allure-results",
    "test:docker": "docker-compose -f docker/docker-compose.test.yml up --abort-on-container-exit",
    "test:aws": "npm run deploy:aws && npm run test",
    "test:azure": "npm run deploy:azure && npm run test",
    "test:gcp": "npm run deploy:gcp && npm run test",
    "deploy:aws": "cdk deploy --profile aws-test",
    "deploy:azure": "az deployment group create --resource-group test-rg --template-file azure/main.bicep",
    "deploy:gcp": "gcloud deployment-manager deployments create test-infra --config gcp/deployment.yaml",
    "setup": "npm install && npx playwright install",
    "setup:mobile": "npm run setup && npx playwright install-deps",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write .",
    "build": "tsc",
    "clean": "rimraf dist allure-results test-results",
    "self-heal": "node src/self-healing/heal-runner.js",
    "generate:tests": "node src/ai/test-generator.js",
    "analyze:failures": "node src/analytics/failure-analyzer.js"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "playwright": "^1.40.0",
    "axios": "^1.6.0",
    "prisma": "^5.6.0",
    "@prisma/client": "^5.6.0",
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "mysql2": "^3.6.5",
    "mongodb": "^6.3.0",
    "redis": "^4.6.10",
    "joi": "^17.11.0",
    "ajv": "^8.12.0",
    "jsonschema": "^1.4.1",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "cross-env": "^7.0.3",
    "allure-playwright": "^2.9.2",
    "allure-commandline": "^2.24.1",
    "opencv4nodejs": "^5.6.0",
    "jimp": "^0.22.10",
    "pixelmatch": "^5.3.0",
    "sharp": "^0.32.6",
    "openai": "^4.20.1",
    "aws-sdk": "^2.1490.0",
    "@azure/identity": "^4.0.1",
    "@azure/storage-blob": "^12.17.0",
    "@google-cloud/storage": "^7.7.0",
    "kubernetes-client": "^10.0.0",
    "docker-compose": "^0.24.2",
    "nodemailer": "^6.9.7",
    "slack-webhook": "^2.0.3",
    "prometheus-register": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/pg": "^8.10.7",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "eslint-plugin-playwright": "^0.18.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2",
    "rimraf": "^5.0.5",
    "k6": "^0.47.0",
    "artillery": "^2.0.3",
    "zaproxy": "^0.2.0",
    "nuclei": "^3.0.4",
    "docker": "^1.0.0",
    "aws-cdk": "^2.108.0",
    "@azure/cli": "^2.54.0",
    "@google-cloud/cli": "^0.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "ui-testing",
    "api-testing",
    "performance-testing",
    "security-testing",
    "database-testing",
    "self-healing",
    "cross-cloud",
    "ci-cd"
  ],
  "author": "Enterprise Test Team",
  "license": "MIT"
}